# HILP External Notification Configuration
# Copy to .env and fill in actual values.

# Slack Bot (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL_ID=C0123456789
SLACK_CPO_USER_ID=U0123456789

# LINE Messaging API (https://developers.line.biz/)
LINE_CHANNEL_ACCESS_TOKEN=your-line-token
LINE_CHANNEL_SECRET=your-channel-secret
LINE_CPO_USER_ID=Uxxxxxxxxxxxx

# GitHub API (for LINE → ideas.md automation)
GITHUB_PAT=ghp_xxxxxxxxxxxx
GITHUB_REPO=AnthroLoop/AnthroLoop
